# Copy this file to .env and adjust as needed.

# MySQL (used by docker-compose to boot the db container)
MYSQL_ROOT_PASSWORD=chainmind_root_pw
MYSQL_DATABASE=chainmind
MYSQL_USER=chainmind_app
MYSQL_PASSWORD=chainmind_app_pw

# Used by the API container to connect to the db container
DATABASE_URL=mysql+pymysql://chainmind_app:chainmind_app_pw@db:3306/chainmind

# Auth
SECRET_KEY=change-this-to-a-long-random-string-before-deploying
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# Set to true on first boot to (re)generate synthetic data and retrain models
SEED_ON_STARTUP=true

# Required only for POST /auth/google (Google sign-in). Create in Google Cloud
# Console > APIs & Services > Credentials > OAuth 2.0 Client ID (Web application),
# with your frontend's exact URL under "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=
